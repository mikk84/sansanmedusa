# ─────────────────────────────────────────────────────────────
# SanSan Medusa — Environment Variables Reference
# Copy to .env and fill in real values. Never commit .env.
# ─────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://sansan:password@localhost:5432/sansan_db

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Medusa ────────────────────────────────────────────────────
MEDUSA_BACKEND_URL=http://localhost:9000
JWT_SECRET=change-me-to-a-random-secret-min-32-chars
COOKIE_SECRET=change-me-to-another-random-secret

# ── Storefront ────────────────────────────────────────────────
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ── Montonio (payments) ───────────────────────────────────────
# Get from: https://developer.montonio.com
MONTONIO_ACCESS_KEY=your-montonio-access-key
MONTONIO_SECRET_KEY=your-montonio-secret-key
MONTONIO_ENVIRONMENT=sandbox  # sandbox | production

# ── Meilisearch (product search) ──────────────────────────────
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=change-me-to-a-random-master-key

# ── Resend (transactional email) ──────────────────────────────
# Get from: https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=tellimused@sansan.ee

# ── Cloudflare R2 (product images) ───────────────────────────
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET=sansan-media
R2_PUBLIC_URL=https://media.sansan.ee

# ── Admin ─────────────────────────────────────────────────────
# Initial admin user created on first run
MEDUSA_ADMIN_EMAIL=admin@sansan.ee
MEDUSA_ADMIN_PASSWORD=change-me-before-going-live
